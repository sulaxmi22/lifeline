# ── Lifeline configuration ─────────────────────────────────────────────
# Copy to .env and fill in. With NO keys set, Lifeline runs fully in DEMO_MODE
# (cached trials + TF-IDF retrieval + local eligibility engine + a clearly
# labeled, representative GPU burst). Add keys to light up the live paths.

# RunPod Flash — required for the LIVE GPU embed/rerank burst (the star path).
RUNPOD_API_KEY=

# Anthropic Claude — required for LIVE eligibility reasoning.
# Without it, a local rule-based engine produces the same strict JSON shape.
ANTHROPIC_API_KEY=

# Flash app identity (used by `flash dev` / `flash deploy`).
FLASH_APP=lifeline
FLASH_ENV=production

# Cost model for the dashboard estimates (USD per GPU-second).
GPU_COST_PER_SECOND=0.00012

# true  => force cached corpus + guaranteed tiers (fast, offline, on-stage safe)
# false => hit live ClinicalTrials.gov; use Flash GPU if RUNPOD_API_KEY is set
DEMO_MODE=true

# ── Optional overrides ────────────────────────────────────────────────
# EMBED_MODEL=BAAI/bge-base-en-v1.5      # swap to bge-large-en-v1.5 for quality
# RERANK_MODEL=BAAI/bge-reranker-base
# CLAUDE_MODEL=claude-sonnet-4-6
# MAX_GPU_WORKERS=8
# EMBED_BATCH_SIZE=48
# MAX_TRIALS=1200
# FLASH_MIN_WORKERS=0   # =1 just before a live demo avoids cold-start lag
                        # (trade-off: no true scale-to-ZERO on the dashboard). See DEPLOY.md.

# ── Frontend ──────────────────────────────────────────────────────────
# The Next.js app reads this (defaults to http://localhost:8000):
# NEXT_PUBLIC_API_BASE=http://localhost:8000
